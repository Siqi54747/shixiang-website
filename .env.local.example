# Copy this file to `.env.local` and fill the values, or export the
# same variables from your shell before running `npm run sync:decks`.
# `.env.local` is gitignored.
#
# Auth model: the sync script calls 飞书 OpenAPI directly using a
# tenant_access_token issued to the `Shixiang-website-publish`
# self-built application. The app must be added as a Base
# collaborator (Reader+) for record reads to succeed.

# Self-built application credentials (from the app's
# 凭证与基础信息 page in 飞书开放平台).
LARK_APP_ID=
LARK_APP_SECRET=

# Decks 多维表格 app_token — 从 Base URL 里抓
# e.g. https://example.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>&view=...
LARK_BASE_APP_TOKEN=

# Decks 表的 table_id — 同上 URL 的 ?table= 参数
LARK_BASE_TABLE_ID=
